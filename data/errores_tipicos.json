  "tipos_de_error": {
    "inversion_letras_sinfon":   "Inversión del orden de letras dentro de un sinfón. Ej: padre → pader. [F1][F7]",
    "inversion_letras_silaba":   "Inversión del orden de letras dentro de una sílaba. Ej: puerta → peurta. [F13][F16]",
    "inversion_silabas":         "Inversión del orden de sílabas completas. Ej: letargo → lagarto. [F3][F1]",
    "omision_consonante_sinfon": "Omisión de una consonante del sinfón. Ej: brazo → bazo. [F1][F5][F13]",
    "omision_letra":             "Omisión de una letra simple. Ej: hermano → hemano. [F3][F13][F17]",
    "omision_silaba":            "Omisión de una sílaba completa. Ej: chocolate → choclate. [F3][F12]",
    "adicion_letra":             "Adición de una letra que no corresponde. Ej: grande → garande. [F9][F17]",
    "adicion_silaba":            "Adición de una sílaba inexistente. Ej: automóvil → automovilil. [F19]",
    "sustitucion_bdpq":          "Sustitución de b/d/p/q entre sí por confusión visual. Ej: perro → derro. [F11][F20]",
    "sustitucion_vocal":         "Sustitución de una vocal por otra similar. Ej: pelo → polo. [F6][F9]",
    "sustitucion_mn":            "Sustitución de m por n antes de p/b. Ej: tampoco → tanpoco. [F8][F18]",
    "sustitucion_grafema":       "Sustitución de grafema por otro fonéticamente similar. Ej: queso → cueso. [F12][F15]",
    "h_omitida":                 "Omisión de la H muda inicial. Ej: haber → aber. [F4][F8][F18]",
    "h_agregada":                "Adición incorrecta de H donde no corresponde. [F8][F18]",
    "confusion_ll_y":            "Sustitución de ll por y o viceversa. Ej: llamar → yamar. [F4][F18]",
    "confusion_b_v":             "Sustitución de b por v o viceversa. Ej: vaca → baca. [F4][F8][F15]",
    "confusion_s_c_z":           "Sustitución de s/c/z entre sí. Ej: hacer → haser. [F4][F8][F20]",
    "confusion_g_j":             "Sustitución de g por j o viceversa ante e/i. Ej: genio → jenio. [F8][F15]",
    "reiteracion_silaba":        "Repetición de una sílaba que no corresponde. Ej: cocina → cocicina. [F1][F3]",
    "traslocacion":              "Traslado de una letra de una sílaba a otra. Ej: borde → boder. [F16]",
    "mezcla":                    "Mezcla de letras y sílabas sin sentido. Ej: ventana → tanvena. [F16]"
  },

